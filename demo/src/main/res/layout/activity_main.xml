<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="🔒 aw-permission 权限库演示"
            android:textColor="#212121"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- 副标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="协程权限请求 · 隐藏Fragment · 永久拒绝检测 · 国产ROM兼容"
            android:textColor="#9E9E9E"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <!-- 日志区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1976D2"
                android:padding="8dp"
                android:text="📋 操作日志"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ScrollView
                android:id="@+id/logScrollView"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="等待操作...\n"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:fontFamily="monospace" />

            </ScrollView>

        </LinearLayout>

        <!-- 基本权限请求 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📱 基本权限请求"
            android:textColor="#424242"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCamera"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="请求 相机权限"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnLocation"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="请求 定位权限(精确定位)"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnMultiple"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="请求 多个权限(相机+录音)"
            android:layout_marginBottom="16dp" />

        <!-- 高级功能 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ 高级功能"
            android:textColor="#424242"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnRationale"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="带 说明的权限请求"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnDsl"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="DSL 风格权限请求"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCheck"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="检查 权限状态"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="打开 应用设置页面"
            android:layout_marginBottom="16dp" />

        <!-- 管理 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔧 管理"
            android:textColor="#424242"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🗑️ 清除日志"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

</ScrollView>
