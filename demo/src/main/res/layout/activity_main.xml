<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?android:attr/colorPrimary"
            app:title="aw-permission 权限库"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_security" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="基本权限"
                        android:textColor="?android:attr/colorPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:drawablePadding="8dp"
                        android:drawableStart="@drawable/ic_permission"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="基础的权限请求功能，支持相机、定位、录音、存储等常用权限的协程请求"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:lineSpacingExtra="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnCamera"
                            style="@style/MaterialButton.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="相机权限"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnLocation"
                            style="@style/MaterialButton.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="定位权限" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <Button
                            android:id="@+id/btnStorage"
                            style="@style/MaterialButton.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="存储/媒体"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnMultiple"
                            style="@style/MaterialButton.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="多个权限" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="高级功能"
                        android:textColor="?android:attr/colorPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:drawablePadding="8dp"
                        android:drawableStart="@drawable/ic_advanced"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="带说明的权限请求、DSL风格请求、权限状态检查、设置页面跳转等高级功能"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:lineSpacingExtra="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnRationale"
                            style="@style/MaterialButton.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="带说明请求"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnDsl"
                            style="@style/MaterialButton.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="DSL风格" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <Button
                            android:id="@+id/btnCheck"
                            style="@style/MaterialButton.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="权限检查"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnSettings"
                            style="@style/MaterialButton.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="设置页面" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="特殊权限"
                        android:textColor="?android:attr/colorPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:drawablePadding="8dp"
                        android:drawableStart="@drawable/ic_security"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="国产ROM特殊权限引导，支持状态检查和设置页跳转"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"
                        android:lineSpacingExtra="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnSpecialFloat"
                            style="@style/MaterialButton.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="悬浮窗"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnSpecialBattery"
                            style="@style/MaterialButton.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="电池优化" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnSpecialNotify"
                        style="@style/MaterialButton.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="通知栏监听"
                        android:layout_marginTop="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="操作日志"
                        android:textColor="?android:attr/colorPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:drawablePadding="8dp"
                        android:drawableStart="@drawable/ic_logs"
                        android:layout_marginBottom="12dp" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:background="?android:attr/colorBackground"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="操作日志将显示在这里...\n点击上方按钮开始测试权限功能"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="4dp" />

                    </ScrollView>

                    <Button
                        android:id="@+id/btnClearLog"
                        style="@style/MaterialButton.Text"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_gravity="end"
                        android:text="清除日志"
                        android:layout_marginTop="12dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
